# App
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://music_user:music_pass@localhost:5432/music_curator

# Provider API credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
LASTFM_API_KEY=your_lastfm_api_key
TIDAL_CLIENT_ID=your_tidal_client_id
TIDAL_CLIENT_SECRET=your_tidal_client_secret
# Must EXACTLY match a redirect URI registered on the developer.tidal.com app
# (scheme, host, port, path, trailing slash). Server-enforced at
# /auth/tidal/authorize — callers cannot override it.
TIDAL_REDIRECT_URI=https://nguyenshane.com/tidal/
YTMUSIC_OAUTH_TOKEN=your_ytmusic_oauth_token
MUSICBRAINZ_USER_AGENT=ShaneMusicCurator/0.1 (you@example.com)

# Security
ENCRYPTION_KEY=replace_with_32_plus_char_secret
